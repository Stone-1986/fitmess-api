# =============================================================================
# fitmess-api — Variables de entorno
# =============================================================================
# Copiar este archivo como .env y completar con valores reales.
# NUNCA subir .env al repositorio.
# =============================================================================

# --- Base de datos (PostgreSQL) ---
DATABASE_URL="postgresql://usuario:password@localhost:5432/fitmess?schema=public"

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- JWT / Autenticación ---
JWT_SECRET="cambiar-por-un-secreto-seguro"
JWT_EXPIRATION="1h"

# --- Sentry (opcional — solo si SENTRY_DSN tiene valor) ---
SENTRY_DSN=""

# --- Resend (Email) ---
RESEND_API_KEY=""

# --- Anthropic (AI) ---
ANTHROPIC_API_KEY=""

# --- Rate Limiting ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
