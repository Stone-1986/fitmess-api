{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Epica fitmess-api",
  "type": "object",
  "required": ["epica"],
  "properties": {
    "epica": {
      "type": "object",
      "required": [
        "id",
        "titulo",
        "objetivo_de_negocio",
        "contexto_de_aplicacion",
        "historias_de_usuario"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^EPICA-\\d+$",
          "description": "Identificador unico de la epica"
        },
        "titulo": {
          "type": "string",
          "minLength": 5
        },
        "objetivo_de_negocio": {
          "type": "string",
          "minLength": 10
        },
        "contexto_de_aplicacion": {
          "type": "string",
          "minLength": 10
        },
        "restricciones_conocidas": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supuestos": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Supuestos documentados durante el analisis que no fueron confirmados por el usuario"
        },
        "glosario": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Terminos clave del dominio con su definicion"
        },
        "dependencias": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["desde", "hacia", "descripcion"],
            "properties": {
              "desde": {
                "type": "string",
                "pattern": "^HU-\\d+$"
              },
              "hacia": {
                "type": "string",
                "pattern": "^HU-\\d+$"
              },
              "descripcion": {
                "type": "string"
              }
            }
          },
          "description": "Dependencias entre Historias de Usuario"
        },
        "historias_de_usuario": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "titulo",
              "como",
              "quiero",
              "para",
              "criterios_de_aceptacion"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^HU-\\d+$"
              },
              "titulo": {
                "type": "string",
                "minLength": 5
              },
              "como": { "type": "string", "minLength": 3 },
              "quiero": { "type": "string", "minLength": 5 },
              "para": { "type": "string", "minLength": 5 },
              "criterios_de_aceptacion": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 10 }
              },
              "reglas_de_negocio": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Reglas de negocio funcionales aplicables a esta HU"
              },
              "notas": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Notas y supuestos especificos de esta HU"
              }
            }
          }
        }
      }
    }
  }
}
